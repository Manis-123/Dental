# ========== API Configuration ==========
# Development:
#   Leave empty or use: http://localhost:4000/api
#   Vite proxy will handle /api requests to backend
#
# Production (Vercel/Netlify):
#   Use your deployed backend URL
#   Example: https://your-backend.onrender.com/api
#           https://your-backend.railway.app/api
#
# IMPORTANT: Make sure to add this to Vercel Environment Variables
#   Project Settings → Environment Variables
#   Add: VITE_API_URL=https://your-deployed-backend.com/api
#
VITE_API_URL=https://your-backend.onrender.com/api
