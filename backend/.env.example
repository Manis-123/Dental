# ========== DATABASE ==========
# MongoDB connection string
# Local: mongodb://localhost:27017/dental_clinic
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dental_clinic
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/dental_clinic?retryWrites=true&w=majority

# ========== AUTHENTICATION ==========
# JWT Secret - MUST be changed in production
# Generate strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ========== CORS - FRONTEND URLs ==========
# Comma-separated list of allowed frontend origins
# Development: http://localhost:3001
# Production: https://your-app.vercel.app,https://www.yourdomain.com
CLIENT_URL=

# ========== ENVIRONMENT ==========
# production | development | staging
NODE_ENV=development

# ========== OPTIONAL: SMS/WhatsApp Reminders (Twilio) ==========
# Leave empty to use mock logging instead
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
